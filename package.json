{
  "name": "uniloader",
  "version": "0.9.20",
  "private": true,
  "description": "UniLoader cross-game mod manager prototype with per-game adapters and dependency planning.",
  "scripts": {
    "dev": "tauri dev",
    "build": "tauri build --features custom-protocol",
    "build:app": "tauri build --features custom-protocol --no-bundle",
    "build:web": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "pnpm run typecheck && pnpm run test:frontend && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:frontend": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-deep-link": "^2.4.5",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@vitejs/plugin-react": "^4.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "vite": "^6.0.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "10.4.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "^22.10.5",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "jsdom": "26.1.0",
    "typescript": "^5.7.2",
    "vitest": "3.2.4"
  }
}
