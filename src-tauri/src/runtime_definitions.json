      "notes": "Official stable BepInEx 5 Windows x64 build for Mono Unity games."
    },
    "profileEngines": ["unity-mono"],
    "profileLoaders": ["bepinex"],
    "providerPackages": [
      {
        "provider": "thunderstore",
        "namespacePatterns": ["*"],
        "packagePatterns": ["BepInEx", "BepInExPack", "BepInExPack_*", "*_BepInExPack"]
      },
      {
        "provider": "nexus",
        "namespacePatterns": [],
        "packagePatterns": ["BepInEx", "BepInEx Pack", "BepInExPack", "BepInExPack *", "BepInEx Pack *"]
      }
    ],
    "detectionRules": [
      {
        "all": ["file:BepInEx/core/BepInEx.dll"]
      },
      {
        "all": ["dir:BepInEx", "file-name:doorstop_config.ini", "file-name:winhttp.dll"]
      }
    ]
  },
